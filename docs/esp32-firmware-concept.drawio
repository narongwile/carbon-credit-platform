  <diagram name="4. Per-Product Sensor Mapping" id="fw_map">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1250" math="0" shadow="0">
      <root><mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="fw_map_m_t" value="Per-product channels -&gt; PCB interface (HAL, +fault/quality, +debounce) -&gt; canonical envelope -&gt; EMQX" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#ffffff;strokeColor=#ffffff;fontSize=13;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="60" y="20" width="1150" height="36" as="geometry"/></mxCell>
        <mxCell id="fw_map_blood" value="bloodBOX (host=b)&#10;&#10;temp_c        (I2C)&#10;rh_pct        (I2C)&#10;batt_pct      (ADC)&#10;impact_g      (I2C accel)&#10;gps           (UART)&#10;baro_alt_m    (I2C baro)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="60" y="90" width="250" height="210" as="geometry"/></mxCell>
        <mxCell id="fw_map_fridge" value="refrigeDataLogger (host=c)&#10;&#10;temp_c        (I2C / 1-wire)&#10;door_state    (DI, debounced)&#10;online        (link)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="60" y="330" width="250" height="140" as="geometry"/></mxCell>
        <mxCell id="fw_map_trafo" value="transformersMonitoring (host=t)&#10;&#10;oil_temp_c    (RS485/ADC)&#10;ambient_temp_c(I2C)&#10;dga_h2_ppm    (RS485/analog)&#10;moisture_ppm  (RS485)&#10;oil_level_pct (ADC)&#10;load_pct      (CT/ADC)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="60" y="500" width="250" height="210" as="geometry"/></mxCell>
        <mxCell id="fw_map_deb" value="DI DEBOUNCE / RATE-LIMIT (ISR)&#10;door_state etc. debounced ~50ms&#10;+ rate-limit -&gt; blocks spike floods&#10;into sample queue" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="60" y="735" width="250" height="95" as="geometry"/></mxCell>
        <mxCell id="fw_map_hal" value="HAL / PCB interfaces&#10;&#10;I2C (SDA/SCL)&#10;ADC (CT, battery, level)&#10;DI (door, status)&#10;RS485 (Modbus sensors)&#10;CAN (SN65HVD230)&#10;UART (GPS / 4G / LoRa)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#f5f5f5;strokeColor=#999999;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="430" y="250" width="250" height="260" as="geometry"/></mxCell>
        <mxCell id="fw_map_prof" value="PRODUCT PROFILE&#10;selects active channels,&#10;rates &amp; thresholds&#10;(from retained config)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="430" y="40" width="250" height="150" as="geometry"/></mxCell>
        <mxCell id="fw_map_fault" value="HAL FAULT HANDLING&#10;read fail: open-wire / loose / I2C timeout / NACK&#10;-&gt; quality = error:&lt;code&gt;  (NOT value=0)&#10;stale read -&gt; quality = stale&#10;lets cloud tell 'real 0C' from 'dead sensor'" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="430" y="565" width="250" height="150" as="geometry"/></mxCell>
        <mxCell id="fw_map_env" value="Canonical envelope&#10;sensors/{sid}/raw&#10;{ ts, device_id, product, channel,&#10; value, unit, QUALITY }&#10;quality in {good, stale, error:&lt;code&gt;}&#10;QoS1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#b0e3e6;strokeColor=#0e8088;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="800" y="250" width="250" height="180" as="geometry"/></mxCell>
        <mxCell id="fw_map_ingest" value="EMQX -&gt; per-product ingest&#10;$share/ingest-&lt;product&gt;&#10;resolve host_fk (t|c|b)&#10;-&gt; JOIN *_sensor_specs&#10;bad quality -&gt; flag, don't trend" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="800" y="470" width="250" height="170" as="geometry"/></mxCell>
        <mxCell id="fw_map_e1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#3b3b3b;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_map_blood" target="fw_map_hal"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_map_e2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#3b3b3b;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_map_fridge" target="fw_map_hal"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_map_e3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#3b3b3b;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_map_trafo" target="fw_map_hal"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_map_e4" value="clean edges" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#d6b656;fontSize=10;dashed=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_map_deb" target="fw_map_hal"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_map_e5" value="activate" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#d79b00;fontSize=10;dashed=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_map_prof" target="fw_map_hal"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_map_e6" value="every read" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#b85450;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_map_hal" target="fw_map_fault"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_map_e7" value="value + quality" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#3b3b3b;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_map_fault" target="fw_map_env"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_map_e8" value="mTLS QoS1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#3b3b3b;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_map_env" target="fw_map_ingest"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root></mxGraphModel>
  </diagram>
  <diagram name="5. Link Manager State Machine + diag/log schema" id="fw_linkfsm">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1620" pageHeight="1160" math="0" shadow="0">
      <root><mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="fw_linkfsm_ttl" value="Link Manager FSM (transport failover + MQTT session) with error logging &amp; diag/log payload schema" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=center;verticalAlign=middle;fillColor=#ffffff;strokeColor=#ffffff;fontSize=13;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="60" y="20" width="1200" height="34" as="geometry"/></mxCell>
        <mxCell id="fw_linkfsm_dot" value="" style="ellipse;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#000000;strokeColor=#000000;fontSize=1;fontStyle=0;" vertex="1" parent="1"><mxGeometry x="96" y="150" width="22" height="22" as="geometry"/></mxCell>
        <mxCell id="fw_linkfsm_conning" value="CONNECTING&#10;&#10;try transport in order:&#10;Wi-Fi -&gt; 4G -&gt; LoRa&#10;(per-transport timeout)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=center;verticalAlign=middle;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="170" y="110" width="210" height="110" as="geometry"/></mxCell>
        <mxCell id="fw_linkfsm_conn" value="CONNECTED&#10;&#10;entry / publish birth (retain)&#10;drain EGRESS (Alarm QoS1 &gt; Telemetry)&#10;FLUSH error-log -&gt; diag/log&#10;heartbeat 30s, keepalive 60s" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=center;verticalAlign=middle;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="500" y="90" width="300" height="150" as="geometry"/></mxCell>
        <mxCell id="fw_linkfsm_recon" value="RECONNECTING&#10;&#10;quick retry on SAME transport&#10;(short, fixed delay)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=center;verticalAlign=middle;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="910" y="110" width="230" height="110" as="geometry"/></mxCell>
        <mxCell id="fw_linkfsm_backoff" value="BACKOFF&#10;&#10;exponential backoff (cap + jitter)&#10;sleep timer; cycle transports&#10;-&gt; protects battery / avoids ban" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=center;verticalAlign=middle;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="500" y="330" width="300" height="120" as="geometry"/></mxCell>
        <mxCell id="fw_linkfsm_offline" value="OFFLINE&#10;&#10;no transport available&#10;entry / store-and-forward (SD, drop-oldest)&#10;buffer error-logs in NVS ring&#10;periodic wake to retry" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=center;verticalAlign=middle;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="110" y="330" width="300" height="140" as="geometry"/></mxCell>
        <mxCell id="fw_linkfsm_logger" value="ERROR / EVENT LOGGER&#10;NVS ring buffer&#10;{ts,from,to,reason,&#10; transport,rssi,level}" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=center;verticalAlign=middle;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="910" y="300" width="250" height="110" as="geometry"/></mxCell>
        <mxCell id="fw_linkfsm_cloud" value="EMQX -&gt; {tenant}/{product}/{device}/diag/log (QoS1)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=center;verticalAlign=middle;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="870" y="440" width="290" height="60" as="geometry"/></mxCell>
        <mxCell id="fw_linkfsm_schema" value="diag/log  payload schema v1     topic: {tenant}/{product}/{device}/diag/log   QoS1  retain=0&#10;------------------------------------------------------------------------------&#10;{&#10;  &quot;v&quot;: 1,                       // schema version&#10;  &quot;device_id&quot;: &quot;ac-fridge-0042&quot;,&#10;  &quot;tenant&quot;: &quot;acme&quot;,&#10;  &quot;product&quot;: &quot;carbonbox&quot;,       // eternity | carbonbox | bloodbox&#10;  &quot;fw&quot;: &quot;1.4.2&quot;,&#10;  &quot;boot_id&quot;: 137,                // ++ each boot (detect resets)&#10;  &quot;sent_at&quot;: 1733740800000,      // wall clock at flush (epoch ms)&#10;  &quot;uptime_s&quot;: 86230,             // device uptime at flush&#10;  &quot;dropped&quot;: 4,                  // entries lost to ring overflow&#10;  &quot;events&quot;: [                    // batch flushed from NVS ring&#10;    {&#10;      &quot;seq&quot;: 5012,              // monotonic per device (gap/dedupe)&#10;      &quot;t&quot;: 1733740123000,       // epoch ms, or null if pre-time-sync&#10;      &quot;up&quot;: 85553,              // uptime_s when logged (ALWAYS set)&#10;      &quot;lvl&quot;: &quot;warn&quot;,            // info | warn | err | fatal&#10;      &quot;code&quot;: &quot;LINK_KEEPALIVE_MISS&quot;,&#10;      &quot;from&quot;: &quot;CONNECTED&quot;,      // FSM state&#10;      &quot;to&quot;: &quot;RECONNECTING&quot;,&#10;      &quot;tr&quot;: &quot;wifi&quot;,             // wifi | lte | lora | none&#10;      &quot;rssi&quot;: -78,&#10;      &quot;msg&quot;: &quot;3 keepalives missed&quot;,&#10;      &quot;ctx&quot;: { &quot;heap&quot;: 142000, &quot;retries&quot;: 0 }   // optional&#10;    }&#10;  ]&#10;}&#10;------------------------------------------------------------------------------&#10;NOTES&#10; * Batched: one PUB flushes many ring entries on entering CONNECTED.&#10; * Offline-safe time: 't' may be null (logged before NTP/cell sync); 'up'&#10;   is always present so ingest back-computes wall time = sent_at-(uptime_s-up).&#10; * 'seq' monotonic -&gt; broker side detects gaps; 'dropped' reports ring loss.&#10; * Alarms are NOT sent here (they use .../alarm/{sid}); diag/log is operational." style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=left;verticalAlign=top;fontFamily=Courier New;spacingLeft=6;spacingTop=4;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;fontStyle=0;" vertex="1" parent="1"><mxGeometry x="640" y="560" width="910" height="540" as="geometry"/></mxCell>
        <mxCell id="fw_linkfsm_codes" value="DIAGNOSTIC CODES        code            | lvl   | LED blink | meaning&#10;----------------------------------------------------------------------&#10;HW_SD_FAIL              err     2x long    SD mount/format failed&#10;HW_I2C_TIMEOUT          err     3x long    I2C bus stuck -&gt; recover&#10;HW_SELFTEST_OK          info    --         all buses OK&#10;SENSOR_OPEN_WIRE        warn    2x short    open/loose -&gt; quality=error&#10;SENSOR_I2C_NACK         warn    2x short    no ACK    -&gt; quality=error&#10;SENSOR_STALE            warn    --          no fresh  -&gt; quality=stale&#10;PROV_TOKEN_FAIL         err     4x long     factory token rejected&#10;PROV_OK                 info    --          cert provisioned&#10;LINK_ALL_FAILED         err     1Hz         wifi+4G+lora all down&#10;LINK_KEEPALIVE_MISS     warn    --          -&gt; RECONNECTING&#10;LINK_PUBLISH_FAIL       warn    --          publish err / requeue&#10;LINK_BACKOFF            info    --          backoff timer armed&#10;LINK_OFFLINE            err     1Hz         store-and-forward active&#10;LINK_RESTORED           info    --          CONNECTED, flushing log&#10;BUF_OVERFLOW_DROP       warn    --          ring full -&gt; drop oldest&#10;OTA_VERIFY_FAIL         err     5x short    SHA/secure-boot mismatch&#10;OTA_ROLLBACK            err     5x short    A/B partition reverted&#10;WDT_RESET               fatal   solid       task hang -&gt; reset&#10;BROWNOUT                fatal   solid       power-dip reset" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=left;verticalAlign=top;fontFamily=Courier New;spacingLeft=6;spacingTop=4;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;fontStyle=0;" vertex="1" parent="1"><mxGeometry x="60" y="560" width="560" height="540" as="geometry"/></mxCell>
        <mxCell id="fw_linkfsm_e1" value="boot / link bring-up" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#3b3b3b;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_linkfsm_dot" target="fw_linkfsm_conning"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_linkfsm_e2" value="link + MQTT ok / birth" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#82b366;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_linkfsm_conning" target="fw_linkfsm_conn"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_linkfsm_e3" value="all transports failed / log(err)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#b85450;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_linkfsm_conning" target="fw_linkfsm_backoff"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_linkfsm_e4" value="keepalive miss | publish fail | link down / log(warn)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#d79b00;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_linkfsm_conn" target="fw_linkfsm_recon"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_linkfsm_e5" value="reconnect ok" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#82b366;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_linkfsm_recon" target="fw_linkfsm_conn"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_linkfsm_e6" value="retry &gt; N / log(err)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#b85450;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_linkfsm_recon" target="fw_linkfsm_backoff"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_linkfsm_e7" value="backoff timer expires / next transport" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#d6b656;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;exitX=0.5;exitY=0;entryX=0.5;entryY=1;" edge="1" parent="1" source="fw_linkfsm_backoff" target="fw_linkfsm_conning"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_linkfsm_e8" value="max backoff &amp; no transport / log(err)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#b85450;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_linkfsm_backoff" target="fw_linkfsm_offline"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_linkfsm_e9" value="periodic wake / retry" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#d6b656;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;exitX=0.5;exitY=0;entryX=0;entryY=0.5;" edge="1" parent="1" source="fw_linkfsm_offline" target="fw_linkfsm_conning"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_linkfsm_e10" value="log(event)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#9673a6;fontSize=10;dashed=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_linkfsm_conning" target="fw_linkfsm_logger"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_linkfsm_e11" value="log(event)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#9673a6;fontSize=10;dashed=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_linkfsm_recon" target="fw_linkfsm_logger"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_linkfsm_e12" value="log(event)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#9673a6;fontSize=10;dashed=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_linkfsm_backoff" target="fw_linkfsm_logger"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_linkfsm_e13" value="log(event)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#9673a6;fontSize=10;dashed=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_linkfsm_offline" target="fw_linkfsm_logger"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_linkfsm_e14" value="flush()" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#82b366;fontSize=10;dashed=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_linkfsm_conn" target="fw_linkfsm_logger"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_linkfsm_e15" value="PUB when CONNECTED" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#9673a6;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_linkfsm_logger" target="fw_linkfsm_cloud"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root></mxGraphModel>
  </diagram>
</mxfile>