        <mxCell id="fw_map_m_t" value="Per-product channels -&gt; PCB interface (HAL) -&gt; canonical envelope -&gt; EMQX" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#ffffff;strokeColor=#ffffff;fontSize=13;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="60" y="20" width="1100" height="36" as="geometry"/></mxCell>
        <mxCell id="fw_map_blood" value="bloodBOX (host=b)&#10;&#10;temp_c        (I2C)&#10;rh_pct        (I2C)&#10;batt_pct      (ADC)&#10;impact_g      (I2C accel)&#10;gps           (UART)&#10;baro_alt_m    (I2C baro)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="60" y="90" width="250" height="210" as="geometry"/></mxCell>
        <mxCell id="fw_map_fridge" value="refrigeDataLogger (host=c)&#10;&#10;temp_c        (I2C / 1-wire)&#10;door_state    (DI)&#10;online        (link)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="60" y="330" width="250" height="140" as="geometry"/></mxCell>
        <mxCell id="fw_map_trafo" value="transformersMonitoring (host=t)&#10;&#10;oil_temp_c    (RS485/ADC)&#10;ambient_temp_c(I2C)&#10;dga_h2_ppm    (RS485/analog)&#10;moisture_ppm  (RS485)&#10;oil_level_pct (ADC)&#10;load_pct      (CT/ADC)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="60" y="500" width="250" height="210" as="geometry"/></mxCell>
        <mxCell id="fw_map_hal" value="HAL / PCB interfaces&#10;&#10;I2C (SDA/SCL)&#10;ADC (CT, battery, level)&#10;DI (door, status)&#10;RS485 (Modbus sensors)&#10;CAN (SN65HVD230)&#10;UART (GPS / 4G / LoRa)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#f5f5f5;strokeColor=#999999;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="430" y="250" width="250" height="260" as="geometry"/></mxCell>
