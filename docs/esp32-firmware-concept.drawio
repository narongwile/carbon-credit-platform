<mxfile host="app.diagrams.net" type="device">
  <diagram name="1. Firmware Architecture" id="fw_arch">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="1050" math="0" shadow="0">
      <root><mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="fw_arch_title" value="ESP32-S3 Unified Firmware - Layered Concept (compatible: bloodBOX / refrigeDataLogger / transformersMonitoring)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#ffffff;strokeColor=#ffffff;fontSize=14;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="160" y="30" width="1060" height="40" as="geometry"/></mxCell>
        <mxCell id="fw_arch_sec" value="SECURITY&#10;&#10;Secure boot (eFuse)&#10;Flash encryption&#10;mTLS X.509 per device&#10;NVS-encrypted creds&#10;ACL: tenant/product/device" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=1;" vertex="1" parent="1"><mxGeometry x="20" y="120" width="130" height="620" as="geometry"/></mxCell>
        <mxCell id="fw_arch_rtos" value="RTOS + RELIABILITY&#10;&#10;FreeRTOS tasks&#10;Task watchdog (TWDT)&#10;Brown-out detector&#10;Store-and-forward (SD)&#10;A/B OTA + rollback" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=1;" vertex="1" parent="1"><mxGeometry x="1230" y="120" width="140" height="620" as="geometry"/></mxCell>
        <mxCell id="fw_arch_l7" value="CLOUD / EMQX (MQTT 5.0 broker)&#10;provisioning - telemetry - heartbeat - status(LWT) - config(retained) - cmd - ota - alarm   |   per-product ingest ($share/ingest-&lt;product&gt;)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="170" y="120" width="1050" height="70" as="geometry"/></mxCell>
        <mxCell id="fw_arch_l6" value="CONNECTIVITY LAYER&#10;Link manager: Wi-Fi -&gt; 4G(LTE) -&gt; LoRa(E220) failover  |  MQTT5 client (mTLS, QoS, LWT/birth)  |  Provisioning client (bootstrap token -&gt; cert)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="170" y="205" width="1050" height="70" as="geometry"/></mxCell>
        <mxCell id="fw_arch_l5" value="APPLICATION SERVICES&#10;Sensor sampler  |  Edge alarm engine (fast-path)  |  Telemetry serializer (canonical envelope)  |  Config manager  |  OTA agent  |  Ring buffer / replay" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#b0e3e6;strokeColor=#0e8088;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="170" y="290" width="1050" height="70" as="geometry"/></mxCell>
        <mxCell id="fw_arch_l4" value="** PRODUCT PROFILE / ABSTRACTION **  (the compatibility layer)&#10;profile = { product_id, channel_set, sample_rates, thresholds, transport }  loaded from retained config/NVS&#10;-&gt; selects which drivers + channels are ACTIVE; the layers above are 100% product-agnostic" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="170" y="375" width="1050" height="80" as="geometry"/></mxCell>
        <mxCell id="fw_arch_l3" value="DRIVER LAYER&#10;temp - humidity - accel/impact - GPS - barometer - DGA(H2) - door(DI) - current(CT) - relay(DO) - LCD - FATFS(SD) - 4G modem - LoRa" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="170" y="470" width="1050" height="70" as="geometry"/></mxCell>
        <mxCell id="fw_arch_l2" value="HAL / BSP&#10;pin-map (GPIO13/14 CAN, GPIO10 RS485-DE, TX0/RX0, TX1/RX1, SDA/SCL, ADC, IO19/20 USB)  |  bus drivers: I2C/UART/SPI/ADC/GPIO/CAN  |  partition table (A/B)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#f5f5f5;strokeColor=#999999;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="170" y="555" width="1050" height="70" as="geometry"/></mxCell>
        <mxCell id="fw_arch_l1" value="HARDWARE - ESP32-S3-WROOM-1 (N16R8) + PCB&#10;CAN (SN65HVD230) - RS485 (MAX3485) - 4G-UART - LoRa E220-900 - I2C/LCD - ADC/CT - DI - DO1/DO2(12V) - SD - USB - LEDs - Power 12V/5V/3V3 - RST/BOOT/JTAG" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="170" y="640" width="1050" height="80" as="geometry"/></mxCell>
        <mxCell id="fw_arch_e1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#999999;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_arch_l1" target="fw_arch_l2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_arch_e2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#999999;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_arch_l2" target="fw_arch_l3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_arch_e3" value="activate channels" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#d79b00;fontSize=10;dashed=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_arch_l4" target="fw_arch_l3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_arch_e4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#82b366;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_arch_l3" target="fw_arch_l5"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_arch_e5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#0e8088;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_arch_l5" target="fw_arch_l6"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_arch_e6" value="telemetry (up)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#82b366;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_arch_l6" target="fw_arch_l7"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_arch_e7" value="config / cmd / ota (down)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#d79b00;fontSize=10;dashed=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_arch_l7" target="fw_arch_l6"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root></mxGraphModel>
  </diagram>
  <diagram name="2. Boot &amp; Provisioning Flow" id="fw_boot">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="1050" math="0" shadow="0">
      <root><mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="fw_boot_b0" value="Power-on" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="480" y="30" width="160" height="50" as="geometry"/></mxCell>
        <mxCell id="fw_boot_b1" value="Secure boot + flash-decrypt&#10;load bootloader (A/B slot)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=0;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="460" y="110" width="240" height="60" as="geometry"/></mxCell>
        <mxCell id="fw_boot_b2" value="Init HAL/BSP, mount NVS + FATFS(SD)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=0;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="460" y="200" width="240" height="50" as="geometry"/></mxCell>
        <mxCell id="fw_boot_b3" value="Provisioned?&#10;(cert + product_id in NVS)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="460" y="280" width="240" height="80" as="geometry"/></mxCell>
        <mxCell id="fw_boot_p1" value="BOOTSTRAP&#10;TLS(server) + factory token" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=0;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="60" y="290" width="230" height="60" as="geometry"/></mxCell>
        <mxCell id="fw_boot_p2" value="PUB provisioning/{chip_id}/request" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=0;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="60" y="375" width="230" height="50" as="geometry"/></mxCell>
        <mxCell id="fw_boot_p3" value="Receive cert + client_id&#10;+ device_id + product_id" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=0;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="60" y="455" width="230" height="60" as="geometry"/></mxCell>
        <mxCell id="fw_boot_p4" value="Store creds in encrypted NVS&#10;-&gt; reboot" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=0;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="60" y="545" width="230" height="60" as="geometry"/></mxCell>
        <mxCell id="fw_boot_b4" value="Load cert + PRODUCT PROFILE&#10;(channel_set, rates, thresholds)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=0;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="460" y="400" width="240" height="60" as="geometry"/></mxCell>
        <mxCell id="fw_boot_b5" value="Init ACTIVE sensor/actuator drivers&#10;per profile" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=0;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="460" y="490" width="240" height="60" as="geometry"/></mxCell>
        <mxCell id="fw_boot_b6" value="Link bring-up: Wi-Fi -&gt; 4G -&gt; LoRa" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=0;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="460" y="575" width="240" height="50" as="geometry"/></mxCell>
        <mxCell id="fw_boot_b7" value="MQTT connect (mTLS, clean_start=0,&#10;LWT status=offline retain)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=0;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="460" y="650" width="240" height="60" as="geometry"/></mxCell>
        <mxCell id="fw_boot_b8" value="PUB birth status=online (retain)&#10;SUB config / cmd / ota" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=0;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="460" y="735" width="240" height="60" as="geometry"/></mxCell>
        <mxCell id="fw_boot_b9" value="Apply retained config (thresholds)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=0;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="460" y="825" width="240" height="50" as="geometry"/></mxCell>
        <mxCell id="fw_boot_b10" value="Enter RUNTIME (see page 3)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="460" y="900" width="240" height="50" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#3b3b3b;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_boot_b0" target="fw_boot_b1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#3b3b3b;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_boot_b1" target="fw_boot_b2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#3b3b3b;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_boot_b2" target="fw_boot_b3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e4" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#b85450;fontSize=10;dashed=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_boot_b3" target="fw_boot_p1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#3b3b3b;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_boot_p1" target="fw_boot_p2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e6" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#3b3b3b;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_boot_p2" target="fw_boot_p3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e7" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#3b3b3b;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_boot_p3" target="fw_boot_p4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e8" value="reboot" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#999999;fontSize=10;dashed=1;labelBackgroundColor=#ffffff;exitX=0.5;exitY=0;entryX=0;entryY=0.5;" edge="1" parent="1" source="fw_boot_p4" target="fw_boot_b1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e9" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#82b366;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_boot_b3" target="fw_boot_b4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e10" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#3b3b3b;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_boot_b4" target="fw_boot_b5"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e11" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#3b3b3b;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_boot_b5" target="fw_boot_b6"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e12" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#3b3b3b;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_boot_b6" target="fw_boot_b7"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e13" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#3b3b3b;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_boot_b7" target="fw_boot_b8"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e14" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#3b3b3b;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_boot_b8" target="fw_boot_b9"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e15" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#3b3b3b;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_boot_b9" target="fw_boot_b10"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root></mxGraphModel>
  </diagram>
  <diagram name="3. Runtime Tasks &amp; Data Flow" id="fw_runtime">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="1050" math="0" shadow="0">
      <root><mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="fw_runtime_r_t" value="RUNTIME - FreeRTOS tasks, queues &amp; data flow (one firmware, profile-driven)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#ffffff;strokeColor=#ffffff;fontSize=13;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="60" y="20" width="1000" height="36" as="geometry"/></mxCell>
        <mxCell id="fw_runtime_sens" value="SensorTask&#10;sample ACTIVE channels&#10;at per-profile rates" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="60" y="90" width="200" height="80" as="geometry"/></mxCell>
        <mxCell id="fw_runtime_q1" value="sample queue" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#f5f5f5;strokeColor=#999999;fontSize=11;fontStyle=0;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="300" y="110" width="150" height="50" as="geometry"/></mxCell>
        <mxCell id="fw_runtime_alarm" value="EdgeAlarmTask&#10;eval thresholds (retained cfg)&#10;breach -&gt; immediate publish" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="490" y="80" width="220" height="80" as="geometry"/></mxCell>
        <mxCell id="fw_runtime_tele" value="TelemetryTask&#10;serialize canonical envelope&#10;per-channel PUB (QoS1)&#10;heartbeat 30s (QoS0)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#b0e3e6;strokeColor=#0e8088;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="490" y="190" width="220" height="90" as="geometry"/></mxCell>
        <mxCell id="fw_runtime_buf" value="Ring buffer / SD&#10;store-and-forward&#10;(replay on reconnect)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="300" y="200" width="160" height="80" as="geometry"/></mxCell>
        <mxCell id="fw_runtime_link" value="LinkMgr / ConnTask&#10;Wi-Fi/4G/LoRa failover&#10;MQTT keepalive + reconnect" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="760" y="120" width="220" height="90" as="geometry"/></mxCell>
        <mxCell id="fw_runtime_broker" value="EMQX broker&#10;(mTLS)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="1030" y="130" width="150" height="70" as="geometry"/></mxCell>
        <mxCell id="fw_runtime_cfg" value="ConfigTask&#10;retained config -&gt;&#10;thresholds, sample rates" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="60" y="320" width="220" height="80" as="geometry"/></mxCell>
        <mxCell id="fw_runtime_cmd" value="CmdTask&#10;cmd/{op}: reboot,&#10;calibrate, set-threshold" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="320" y="320" width="210" height="80" as="geometry"/></mxCell>
        <mxCell id="fw_runtime_ota" value="OTATask&#10;ota/cmd -&gt; HTTPS fetch -&gt;&#10;SHA256+secureboot -&gt; A/B -&gt; rollback" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="560" y="320" width="260" height="80" as="geometry"/></mxCell>
        <mxCell id="fw_runtime_wdt" value="Watchdog (TWDT)&#10;monitors all tasks -&gt;&#10;reset on hang" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="860" y="320" width="220" height="80" as="geometry"/></mxCell>
