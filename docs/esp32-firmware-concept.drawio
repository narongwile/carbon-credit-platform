  </diagram>
  <diagram name="3. Runtime Tasks &amp; Data Flow" id="fw_runtime">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1250" math="0" shadow="0">
      <root><mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="fw_runtime_r_t" value="RUNTIME - FreeRTOS tasks, queues &amp; data flow (profile-driven, fault-tolerant)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#ffffff;strokeColor=#ffffff;fontSize=13;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="60" y="20" width="1100" height="36" as="geometry"/></mxCell>
        <mxCell id="fw_runtime_sens" value="SensorTask&#10;sample ACTIVE channels&#10;at per-profile rates" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="60" y="100" width="200" height="80" as="geometry"/></mxCell>
        <mxCell id="fw_runtime_q1" value="sample queue" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#f5f5f5;strokeColor=#999999;fontSize=11;fontStyle=0;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="300" y="115" width="150" height="50" as="geometry"/></mxCell>
        <mxCell id="fw_runtime_alarm" value="EdgeAlarmTask&#10;eval thresholds (retained cfg)&#10;breach -&gt; enqueue alarm" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="490" y="70" width="220" height="80" as="geometry"/></mxCell>
        <mxCell id="fw_runtime_tele" value="TelemetryTask&#10;serialize envelope (+quality)&#10;per-channel + heartbeat" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#b0e3e6;strokeColor=#0e8088;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="490" y="185" width="220" height="85" as="geometry"/></mxCell>
        <mxCell id="fw_runtime_buf" value="Ring buffer / SD&#10;store-and-forward&#10;POLICY: FIFO drop-OLDEST&#10;(telemetry); NEVER drop alarms" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="300" y="215" width="180" height="105" as="geometry"/></mxCell>
        <mxCell id="fw_runtime_egr" value="EGRESS / PUBLISH QUEUE&#10;single producer-of-record&#10;priority: ALARM(QoS1) &gt; Telemetry&#10;LinkMgr drains 1-by-1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#b0e3e6;strokeColor=#0e8088;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="760" y="110" width="230" height="100" as="geometry"/></mxCell>
        <mxCell id="fw_runtime_link" value="LinkMgr / ConnTask&#10;Wi-Fi/4G/LoRa failover (+backoff)&#10;MQTT keepalive + reconnect" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="1040" y="115" width="230" height="90" as="geometry"/></mxCell>
        <mxCell id="fw_runtime_broker" value="EMQX broker&#10;(mTLS)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="1330" y="130" width="140" height="70" as="geometry"/></mxCell>
        <mxCell id="fw_runtime_cfg" value="ConfigTask&#10;retained config -&gt;&#10;thresholds, sample rates" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="60" y="380" width="220" height="80" as="geometry"/></mxCell>
        <mxCell id="fw_runtime_cmd" value="CmdTask&#10;cmd/{op}: reboot,&#10;calibrate, set-threshold" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="320" y="380" width="210" height="80" as="geometry"/></mxCell>
        <mxCell id="fw_runtime_ota" value="OTATask&#10;ota/cmd -&gt; fetch -&gt; SHA256&#10;+secureboot -&gt; A/B -&gt; rollback" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="570" y="380" width="250" height="80" as="geometry"/></mxCell>
        <mxCell id="fw_runtime_wdt" value="WATCHDOG Task (TWDT)&#10;each task feeds a heartbeat flag&#10;missing flag -&gt; targeted reset&#10;(pinpoints the hung task)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="860" y="380" width="260" height="90" as="geometry"/></mxCell>
        <mxCell id="fw_runtime_e1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#3b3b3b;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_runtime_sens" target="fw_runtime_q1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_runtime_e2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#b85450;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_runtime_q1" target="fw_runtime_alarm"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_runtime_e3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#0e8088;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_runtime_q1" target="fw_runtime_tele"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_runtime_e4" value="high prio" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#b85450;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_runtime_alarm" target="fw_runtime_egr"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_runtime_e5" value="normal" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#0e8088;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_runtime_tele" target="fw_runtime_egr"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_runtime_e6" value="drain 1-by-1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#3b3b3b;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_runtime_egr" target="fw_runtime_link"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_runtime_e7" value="mTLS / QoS" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#3b3b3b;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_runtime_link" target="fw_runtime_broker"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_runtime_e8" value="offline -&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#d6b656;fontSize=10;dashed=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_runtime_tele" target="fw_runtime_buf"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_runtime_e9" value="replay" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#d6b656;fontSize=10;dashed=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_runtime_buf" target="fw_runtime_egr"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_runtime_e10" value="config/cmd/ota (down)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#9673a6;fontSize=10;dashed=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_runtime_broker" target="fw_runtime_link"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_runtime_e11" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#3b3b3b;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_runtime_link" target="fw_runtime_cfg"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_runtime_e12" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#3b3b3b;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_runtime_link" target="fw_runtime_cmd"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_runtime_e13" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#3b3b3b;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_runtime_link" target="fw_runtime_ota"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_runtime_e14" value="new thresholds" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#d79b00;fontSize=10;dashed=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_runtime_cfg" target="fw_runtime_alarm"><mxGeometry relative="1" as="geometry"/></mxCell>
