        <mxCell id="fw_boot_e26" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#3b3b3b;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_boot_b9" target="fw_boot_b10"><mxGeometry relative="1" as="geometry"/></mxCell>
