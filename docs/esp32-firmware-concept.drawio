<mxfile host="app.diagrams.net" type="device">
  <diagram name="1. Firmware Architecture" id="fw_arch">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1250" math="0" shadow="0">
      <root><mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="fw_arch_title" value="ESP32-S3 Unified Firmware - Layered Concept (compatible: bloodBOX / refrigeDataLogger / transformersMonitoring)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#ffffff;strokeColor=#ffffff;fontSize=14;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="160" y="30" width="1060" height="40" as="geometry"/></mxCell>
        <mxCell id="fw_arch_sec" value="SECURITY&#10;&#10;Secure boot (eFuse)&#10;Flash encryption&#10;mTLS X.509 per device&#10;NVS-encrypted creds&#10;ACL: tenant/product/device" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=1;" vertex="1" parent="1"><mxGeometry x="20" y="120" width="130" height="620" as="geometry"/></mxCell>
        <mxCell id="fw_arch_rtos" value="RTOS + RELIABILITY&#10;&#10;FreeRTOS tasks&#10;Watchdog: per-task heartbeat&#10;Brown-out detector&#10;Safe Mode / error LED codes&#10;Store-and-forward (SD)&#10;A/B OTA + rollback" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=1;" vertex="1" parent="1"><mxGeometry x="1230" y="120" width="140" height="620" as="geometry"/></mxCell>
        <mxCell id="fw_arch_l7" value="CLOUD / EMQX (MQTT 5.0 broker)&#10;provisioning - telemetry - heartbeat - status(LWT) - config(retained) - cmd - ota - alarm   |   per-product ingest ($share/ingest-&lt;product&gt;)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="170" y="120" width="1050" height="70" as="geometry"/></mxCell>
        <mxCell id="fw_arch_l6" value="CONNECTIVITY LAYER&#10;Link manager: Wi-Fi -&gt; 4G(LTE) -&gt; LoRa(E220) failover (+exp backoff)  |  MQTT5 client (mTLS, QoS, LWT/birth)  |  Provisioning client (token -&gt; cert)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="170" y="205" width="1050" height="70" as="geometry"/></mxCell>
        <mxCell id="fw_arch_l5" value="APPLICATION SERVICES&#10;Sensor sampler  |  Edge alarm engine (fast-path)  |  Telemetry serializer (envelope+quality)  |  Egress queue (Alarm&gt;Telemetry)  |  Config mgr  |  OTA agent  |  Ring buffer (drop-oldest)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#b0e3e6;strokeColor=#0e8088;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="170" y="290" width="1050" height="70" as="geometry"/></mxCell>
        <mxCell id="fw_arch_l4" value="** PRODUCT PROFILE / ABSTRACTION **  (the compatibility layer)&#10;profile = { product_id, channel_set, sample_rates, thresholds, transport }  loaded from retained config/NVS&#10;-&gt; selects which drivers + channels are ACTIVE; the layers above are 100% product-agnostic" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="170" y="375" width="1050" height="80" as="geometry"/></mxCell>
        <mxCell id="fw_arch_l3" value="DRIVER LAYER  (+ fault detection -&gt; quality code, + DI debounce in ISR)&#10;temp - humidity - accel/impact - GPS - barometer - DGA(H2) - door(DI) - current(CT) - relay(DO) - LCD - FATFS(SD) - 4G modem - LoRa" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="170" y="470" width="1050" height="70" as="geometry"/></mxCell>
        <mxCell id="fw_arch_l2" value="HAL / BSP&#10;pin-map (GPIO13/14 CAN, GPIO10 RS485-DE, TX0/RX0, TX1/RX1, SDA/SCL, ADC, IO19/20 USB)  |  bus drivers: I2C/UART/SPI/ADC/GPIO/CAN  |  partition table (A/B)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#f5f5f5;strokeColor=#999999;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="170" y="555" width="1050" height="70" as="geometry"/></mxCell>
        <mxCell id="fw_arch_l1" value="HARDWARE - ESP32-S3-WROOM-1 (N16R8) + PCB&#10;CAN (SN65HVD230) - RS485 (MAX3485) - 4G-UART - LoRa E220-900 - I2C/LCD - ADC/CT - DI - DO1/DO2(12V) - SD - USB - LEDs - Power 12V/5V/3V3 - RST/BOOT/JTAG" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="170" y="640" width="1050" height="80" as="geometry"/></mxCell>
        <mxCell id="fw_arch_e1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#3b3b3b;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_arch_l1" target="fw_arch_l2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_arch_e2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#3b3b3b;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_arch_l2" target="fw_arch_l3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_arch_e3" value="activate channels" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#d79b00;fontSize=10;dashed=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_arch_l4" target="fw_arch_l3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_arch_e4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#82b366;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_arch_l3" target="fw_arch_l5"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_arch_e5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#0e8088;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_arch_l5" target="fw_arch_l6"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_arch_e6" value="telemetry (up)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#82b366;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_arch_l6" target="fw_arch_l7"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_arch_e7" value="config / cmd / ota (down)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#d79b00;fontSize=10;dashed=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_arch_l7" target="fw_arch_l6"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root></mxGraphModel>
  </diagram>
  <diagram name="2. Boot &amp; Provisioning Flow" id="fw_boot">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1250" math="0" shadow="0">
      <root><mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="fw_boot_b0" value="Power-on" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="560" y="20" width="160" height="46" as="geometry"/></mxCell>
        <mxCell id="fw_boot_b1" value="Secure boot + flash-decrypt&#10;load bootloader (A/B slot)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=0;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="540" y="90" width="250" height="50" as="geometry"/></mxCell>
        <mxCell id="fw_boot_b2" value="Init HAL/BSP, mount NVS + FATFS(SD)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=0;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="540" y="165" width="250" height="50" as="geometry"/></mxCell>
        <mxCell id="fw_boot_hwok" value="HW self-test OK?&#10;(SD / I2C bus / power)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="560" y="235" width="210" height="95" as="geometry"/></mxCell>
        <mxCell id="fw_boot_safe" value="SAFE MODE / ERROR STATE&#10;LED blink error code&#10;log fault to NVS&#10;degrade: skip faulty subsystem&#10;(report-only when link up)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;fontStyle=0;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="170" y="235" width="260" height="120" as="geometry"/></mxCell>
        <mxCell id="fw_boot_b3" value="Provisioned?&#10;(cert + product_id in NVS)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="560" y="360" width="210" height="95" as="geometry"/></mxCell>
        <mxCell id="fw_boot_p1" value="BOOTSTRAP: TLS(server) + factory token" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=0;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="110" y="470" width="250" height="50" as="geometry"/></mxCell>
        <mxCell id="fw_boot_p2" value="PUB provisioning/{chip_id}/request" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=0;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="110" y="540" width="250" height="45" as="geometry"/></mxCell>
        <mxCell id="fw_boot_pok" value="Server OK?&#10;(response received)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="150" y="605" width="180" height="90" as="geometry"/></mxCell>
        <mxCell id="fw_boot_pbk" value="RETRY: exponential backoff&#10;(cap + jitter)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=0;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="110" y="720" width="250" height="55" as="geometry"/></mxCell>
        <mxCell id="fw_boot_p3" value="Receive cert + client_id&#10;+ device_id + product_id" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=0;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="110" y="800" width="250" height="55" as="geometry"/></mxCell>
        <mxCell id="fw_boot_p4" value="Store creds in encrypted NVS" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=0;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="110" y="880" width="250" height="45" as="geometry"/></mxCell>
        <mxCell id="fw_boot_b4" value="Load cert + PRODUCT PROFILE&#10;(channels, rates, thresholds)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=0;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="540" y="485" width="250" height="55" as="geometry"/></mxCell>
        <mxCell id="fw_boot_b5" value="Init ACTIVE drivers per profile" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=0;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="540" y="565" width="250" height="45" as="geometry"/></mxCell>
        <mxCell id="fw_boot_b6" value="Link bring-up: try Wi-Fi -&gt; 4G -&gt; LoRa&#10;(each with timeout)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=0;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="540" y="635" width="250" height="55" as="geometry"/></mxCell>
        <mxCell id="fw_boot_linkok" value="Any link up?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="560" y="710" width="210" height="85" as="geometry"/></mxCell>
        <mxCell id="fw_boot_lbk" value="Wait / light-sleep&#10;+ exponential backoff (cap, jitter)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=0;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="840" y="710" width="250" height="75" as="geometry"/></mxCell>
        <mxCell id="fw_boot_b7" value="MQTT connect&#10;(mTLS, clean_start=0, LWT offline)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=0;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="540" y="820" width="250" height="55" as="geometry"/></mxCell>
        <mxCell id="fw_boot_mqok" value="MQTT connected?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="560" y="895" width="210" height="80" as="geometry"/></mxCell>
        <mxCell id="fw_boot_b8" value="PUB birth status=online (retain)&#10;SUB config / cmd / ota" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=0;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="540" y="1000" width="250" height="55" as="geometry"/></mxCell>
        <mxCell id="fw_boot_b9" value="Apply retained config (thresholds)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=0;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="540" y="1075" width="250" height="45" as="geometry"/></mxCell>
        <mxCell id="fw_boot_b10" value="Enter RUNTIME (page 3)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;dashed=0;" vertex="1" parent="1"><mxGeometry x="560" y="1140" width="210" height="46" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#3b3b3b;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_boot_b0" target="fw_boot_b1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#3b3b3b;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_boot_b1" target="fw_boot_b2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#3b3b3b;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_boot_b2" target="fw_boot_hwok"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e4" value="no - HW fault" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#b85450;fontSize=10;dashed=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_boot_hwok" target="fw_boot_safe"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e5" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#82b366;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_boot_hwok" target="fw_boot_b3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e6" value="report-only link" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#b85450;fontSize=10;dashed=1;labelBackgroundColor=#ffffff;exitX=0.5;exitY=1;entryX=0;entryY=0.5;" edge="1" parent="1" source="fw_boot_safe" target="fw_boot_b6"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e7" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#b85450;fontSize=10;dashed=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_boot_b3" target="fw_boot_p1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e8" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#82b366;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_boot_b3" target="fw_boot_b4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e9" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#3b3b3b;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_boot_p1" target="fw_boot_p2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e10" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#3b3b3b;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_boot_p2" target="fw_boot_pok"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e11" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#b85450;fontSize=10;dashed=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_boot_pok" target="fw_boot_pbk"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e12" value="retry" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#d6b656;fontSize=10;dashed=1;labelBackgroundColor=#ffffff;exitX=1;exitY=0.5;entryX=1;entryY=0.5;" edge="1" parent="1" source="fw_boot_pbk" target="fw_boot_p1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e13" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#82b366;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_boot_pok" target="fw_boot_p3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e14" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#3b3b3b;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_boot_p3" target="fw_boot_p4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e15" value="reboot" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#999999;fontSize=10;dashed=1;labelBackgroundColor=#ffffff;exitX=0.5;exitY=1;entryX=0;entryY=0.3;" edge="1" parent="1" source="fw_boot_p4" target="fw_boot_b1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e16" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#3b3b3b;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_boot_b4" target="fw_boot_b5"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e17" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#3b3b3b;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_boot_b5" target="fw_boot_b6"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e18" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#3b3b3b;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_boot_b6" target="fw_boot_linkok"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e19" value="no - all links failed" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#b85450;fontSize=10;dashed=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_boot_linkok" target="fw_boot_lbk"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e20" value="retry" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#d6b656;fontSize=10;dashed=1;labelBackgroundColor=#ffffff;exitX=0.5;exitY=0;entryX=1;entryY=0.5;" edge="1" parent="1" source="fw_boot_lbk" target="fw_boot_b6"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e21" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#82b366;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_boot_linkok" target="fw_boot_b7"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e22" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#3b3b3b;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_boot_b7" target="fw_boot_mqok"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e23" value="no - backoff" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#b85450;fontSize=10;dashed=1;labelBackgroundColor=#ffffff;exitX=1;exitY=0.5;entryX=0.5;entryY=1;" edge="1" parent="1" source="fw_boot_mqok" target="fw_boot_lbk"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fw_boot_e24" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#82b366;fontSize=10;dashed=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fw_boot_mqok" target="fw_boot_b8"><mxGeometry relative="1" as="geometry"/></mxCell>
