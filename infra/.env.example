# ── THERM Expertise WordPress stack ───────────────────────────────
# Copy this file to ".env" and adjust values before running docker compose.

# WordPress Docker image (release line). The project targets WordPress 7.0;
# pin a concrete tag here, e.g. wordpress:6.5-php8.2-apache.
WP_IMAGE=wordpress:php8.2-apache

# Host ports
WP_PORT=8080
PMA_PORT=8081

# Database
MYSQL_DATABASE=thermexpertise
MYSQL_USER=thex
MYSQL_PASSWORD=change-me-db-password
MYSQL_ROOT_PASSWORD=change-me-root-password

# WordPress
WP_DEBUG=0

# Site configuration (used by scripts/provision.sh)
SITE_URL=http://localhost:8080
SITE_TITLE=THERM Expertise Co., Ltd.
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-admin-password
ADMIN_EMAIL=thermexpertise.thex@gmail.com
