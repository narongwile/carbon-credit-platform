# ── MySQL (defaults match the in-cluster service) ───────────────────────────
DB_HOST=mysql.data.svc.cluster.local
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=iothub.2026
DB_NAME=iothub
DB_TZ=+07:00                  # records written in this tz (Bangkok). UTC = "Z"

# ── MQTT broker (telemetry from devices / Node-RED) ─────────────────────────
MQTT_URL=mqtt://mqtt.data.svc.cluster.local:1883
MQTT_TOPIC=telemetry/#

# ── HTTP ────────────────────────────────────────────────────────────────────
PORT=4000
CORS_ORIGIN=*

# ── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=development          # set "production" to enforce JWT_SECRET + CORS hardening
DISPLAY_TZ=Asia/Bangkok       # human-facing timestamps (notifications) shown in this tz; storage stays UTC

# ── Auth (self-issued JWT) ──────────────────────────────────────────────────
JWT_SECRET=dev-secret-change-me   # MUST change in production (startup fails otherwise)
JWT_TTL=12h
LOGIN_MAX_ATTEMPTS=10         # failed logins per IP per window before 429
LOGIN_WINDOW_MIN=15

# ── Escalation / auto-clear ─────────────────────────────────────────────────
ESCALATE_AFTER_MIN=15
CLEAR_AFTER_MIN=5

# ── Presence / offline detection (ESP32 heartbeat + status) ─────────────────
OFFLINE_AFTER_S=90

# ── Data retention (raw readings rolled to hourly buckets, then purged) ─────
READINGS_RETENTION_DAYS=30

# ── Notification channels (fill to enable real delivery) ────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=alerts@oneops.local

LINE_NOTIFY_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
GOOGLE_CHAT_WEBHOOK=
